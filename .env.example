# CrowdSafe AI — Environment Variables Template
# Copy this file to .env and fill in your credentials.
# The system works fully without these (notifications will be simulated).

# ── Twilio SMS (optional) ──────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM=+1234567890
ALERT_PHONES=+919876543210,+919876543211

# ── Email SMTP (optional) ──────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
ALERT_EMAILS=security@venue.com,admin@venue.com

# ── Webhook (optional — POST on every alert) ──────────────────────────────
WEBHOOK_URL=https://your-command-center.com/webhook/crowd-alert

# ── Weather API (optional) ────────────────────────────────────────────────
OPENWEATHER_API_KEY=your_key_here
